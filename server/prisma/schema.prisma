generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
}

enum TripStatus {
  PLANNING
  ONGOING
  COMPLETED
  SAVED
}

enum BudgetLevel {
  LOW
  MEDIUM
  HIGH
}

enum ActivityCategory {
  SIGHTSEEING
  FOOD
  ADVENTURE
  CULTURE
  SHOPPING
  RELAXATION
  TRANSPORT
}

enum PackingCategory {
  CLOTHING
  ELECTRONICS
  DOCUMENTS
  ESSENTIALS
}

model User {
  id           String       @id @default(cuid())
  firstName    String
  lastName     String
  email        String       @unique
  passwordHash String
  phone        String?
  city         String?
  country      String?
  bio          String?
  avatarUrl    String?
  preferences  Json?
  role         Role         @default(USER)
  trips        Trip[]
  sharedTrips  SharedTrip[]
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@map("users")
}

model Trip {
  id           String        @id @default(cuid())
  userId       String
  title        String
  slug         String
  startingPlace String?
  destinationPlace String?
  description  String?
  coverImage   String?
  startDate    DateTime
  endDate      DateTime
  status       TripStatus    @default(PLANNING)
  isPublic     Boolean       @default(false)
  user         User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  stops        Stop[]
  activities   Activity[]
  budget       Budget?
  packingItems PackingItem[]
  notes        Note[]
  sharedTrips  SharedTrip[]
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@unique([userId, slug])
  @@map("trips")
}

model Stop {
  id          String     @id @default(cuid())
  tripId      String
  city        String
  country     String
  arrivalDate DateTime
  departDate  DateTime
  order       Int
  notes       String?
  trip        Trip       @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activities  Activity[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@map("stops")
}

model Activity {
  id          String           @id @default(cuid())
  stopId      String?
  tripId      String?
  title       String
  category    ActivityCategory @default(SIGHTSEEING)
  description String?
  dayNumber   Int?
  startTime   DateTime?
  duration    Int?
  cost        Decimal          @default(0)
  location    String?
  stop        Stop?            @relation(fields: [stopId], references: [id], onDelete: Cascade)
  trip        Trip?            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@map("activities")
}

model Budget {
  id         String   @id @default(cuid())
  tripId     String   @unique
  total      Decimal  @default(0)
  hotels     Decimal  @default(0)
  transport  Decimal  @default(0)
  food       Decimal  @default(0)
  activities Decimal  @default(0)
  currency   String   @default("INR")
  trip       Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@map("budgets")
}

model PackingItem {
  id        String          @id @default(cuid())
  tripId    String
  name      String
  category  PackingCategory @default(ESSENTIALS)
  packed    Boolean         @default(false)
  trip      Trip            @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt

  @@map("packing_items")
}

model Note {
  id        String   @id @default(cuid())
  tripId    String
  title     String
  content   String
  day       DateTime?
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("notes")
}

model SharedTrip {
  id        String   @id @default(cuid())
  userId    String
  tripId    String
  publicId  String   @unique
  canCopy   Boolean  @default(true)
  views     Int      @default(0)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  trip      Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("shared_trips")
}
